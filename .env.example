# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored, so your real keys never get committed.

# --- Vertex AI auth (Google Cloud Service Account, recommended) ---
# Path to your service-account JSON (see secrets/README.md).
# In Docker this is overridden to /app/secrets/gemini-service-account.json.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gemini-service-account.json
# Vertex region. Gemini 3 models use "global". (Not stored in the SA key, set it here.)
GOOGLE_CLOUD_LOCATION=global
# Optional: the project is read from your SA key's project_id automatically.
# Only set this to target a DIFFERENT project than the SA key's own.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- Supplier matching ---
# Fuzzy-match confidence threshold, 0.0 - 1.0
SUPPLIER_CONFIDENCE_THRESHOLD=0.82

# --- Optional: LangSmith tracing (leave false to disable) ---
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Your LangSmith personal API key (only needed if tracing is enabled)
LANGSMITH_API_KEY=REPLACE_WITH_your_langsmith_key
LANGSMITH_PROJECT="Invoice Archive AI"
