# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored, so your real keys never get committed.

# --- Vertex AI auth (Google Cloud service account, recommended) ---
# 1. Create a service account with Vertex AI access in Google Cloud.
# 2. Download its JSON key and save it as:  secrets/gemini-service-account.json
#    (that folder is git-ignored; see secrets/README.md). The path below points there.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gemini-service-account.json
# Vertex region. Gemini 3 models use "global". Required (it is not stored in the SA key).
GOOGLE_CLOUD_LOCATION=global
# Optional: the project is read from your SA key's project_id automatically.
# Set this only to target a DIFFERENT project than the SA key's own.
# GOOGLE_CLOUD_PROJECT=
# Optional: override the model. Default is gemini-3.1-flash-lite.
# GEMINI_MODEL=

# --- Supplier matching ---
# Fuzzy-match confidence threshold, 0.0 - 1.0.
SUPPLIER_CONFIDENCE_THRESHOLD=0.82

# --- Optional: LangSmith tracing (leave LANGSMITH_TRACING=false to disable) ---
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Your LangSmith API key — only needed when tracing is enabled.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="Invoice Archive AI"
